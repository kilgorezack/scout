# Optional — Scout runs with stub data when these are empty.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional Census API key (higher rate limit; not required for low volume).
CENSUS_API_KEY=

# Required for the per-competitor Deep Dive feature.
# Get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Optional override. Defaults to gemini-2.5-flash. Swap to
# gemini-3-pro-preview for the latest Gemini 3 (smaller free tier),
# or gemini-2.5-pro for richer synthesis.
# GEMINI_MODEL=gemini-2.5-flash

# Optional override — defaults to the public Hotrod BDC bucket.
# HOTROD_BUCKET=hotrod-7a59d.firebasestorage.app
# HOTROD_ENABLED=true

# === Coverage Map (/hotrod) tab ===
# Apple MapKit JS token. Required for the map to render.
# Use the same token as the standalone Hotrod deploy.
# Generate / manage: https://developer.apple.com/account/resources/authkeys
MAPKIT_TOKEN=
# Optional override — defaults to https://hotrod.summitlabs.one/api
# HOTROD_API_BASE=https://hotrod.summitlabs.one/api
