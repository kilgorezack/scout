# Optional — Scout runs with stub data when these are empty.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional Census API key (higher rate limit; not required for low volume).
CENSUS_API_KEY=

# Required for the per-competitor Deep Dive feature.
# Get a free key at https://aistudio.google.com/apikey
# Uses Gemini 3 Flash with Google Search grounding.
GEMINI_API_KEY=

# Optional override — defaults to the public Hotrod BDC bucket.
# HOTROD_BUCKET=hotrod-7a59d.firebasestorage.app
# HOTROD_ENABLED=true
